<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Danh sách công việc -->
    <record id="view_enterprise_task_tree" model="ir.ui.view">
        <field name="name">enterprise.task.tree</field>
        <field name="model">enterprise.task</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="employee_id"/>
                <field name="deadline"/>
                <field name="progress" widget="progressbar"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- Form công việc -->
    <record id="view_enterprise_task_form" model="ir.ui.view">
        <field name="name">enterprise.task.form</field>
        <field name="model">enterprise.task</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>
                        <field name="code" readonly="1"/>
                        <field name="name"/>
                        <field name="project_id"/>
                        <field name="employee_id"/>
                        <field name="start_date"/>
                        <field name="deadline"/>
                        <field name="priority"/>
                        <field name="progress"/>
                        <field name="state"/>
                    </group>

                    <group>
                        <field name="description"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_enterprise_task" model="ir.actions.act_window">
        <field name="name">Quản lý công việc</field>
        <field name="res_model">enterprise.task</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu -->
    <menuitem
        id="menu_enterprise_task"
        name="Quản lý công việc"
        parent="menu_enterprise_root"
        action="action_enterprise_task"
        sequence="20"/>

</odoo>
